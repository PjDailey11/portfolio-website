<%
function renderIcon(name) {
    switch (name) {
        case 'instagram':
            return `
                <rect x="4" y="4" width="16" height="16" rx="5"></rect>
                <circle cx="12" cy="12" r="3.4"></circle>
                <circle cx="17.5" cy="6.5" r="0.75" fill="currentColor" stroke="none"></circle>
            `;
        case 'youtube':
            return `
                <path d="M4.5 8.3c0-1.2.8-2.2 2-2.4 1.6-.3 3.4-.4 5.5-.4s3.9.1 5.5.4c1.2.2 2 1.2 2 2.4.3 1.5.4 2.8.4 3.7s-.1 2.2-.4 3.7c0 1.2-.8 2.2-2 2.4-1.6.3-3.4.4-5.5.4s-3.9-.1-5.5-.4c-1.2-.2-2-1.2-2-2.4-.3-1.5-.4-2.8-.4-3.7s.1-2.2.4-3.7Z"></path>
                <path d="m10 9 5 3-5 3Z" fill="currentColor" stroke="none"></path>
            `;
        case 'linkedin':
            return `
                <rect x="4.5" y="4.5" width="15" height="15" rx="3"></rect>
                <path d="M8 10v6"></path>
                <path d="M8 8h.01"></path>
                <path d="M12 16v-3.2c0-1 .8-1.8 1.8-1.8h0c1 0 1.8.8 1.8 1.8V16"></path>
                <path d="M12 10v6"></path>
            `;
        case 'github':
            return `
                <path d="M9 18c-3 1-3-1.5-4.5-2"></path>
                <path d="M15 21v-3.5a3.1 3.1 0 0 0-.9-2.4c3-.3 6.2-1.5 6.2-6.7a5.2 5.2 0 0 0-1.4-3.6 4.9 4.9 0 0 0-.1-3.6s-1.2-.4-3.8 1.4a13.2 13.2 0 0 0-7 0C5.4 1.2 4.2 1.6 4.2 1.6A4.9 4.9 0 0 0 4 5.2a5.2 5.2 0 0 0-1.4 3.6c0 5.2 3.2 6.4 6.2 6.7a3.1 3.1 0 0 0-.9 2.4V21"></path>
            `;
        case 'tiktok':
            return `
                <path d="M14 5c.6 1.3 1.8 2.3 3.3 2.6v2.5a5.9 5.9 0 0 1-3.3-1v4.3a4.3 4.3 0 1 1-4.3-4.3c.3 0 .6 0 .9.1v2.6a1.8 1.8 0 1 0 1 1.6V3h2.4Z"></path>
            `;
        default:
            return `
                <circle cx="12" cy="12" r="8"></circle>
                <path d="M8 12h8"></path>
                <path d="M12 8v8"></path>
            `;
    }
}
%>
<div class="flex flex-wrap gap-3">
    <% links.forEach(function (item) { %>
        <a href="<%= item.href %>" class="social-icon" target="_blank" rel="noopener noreferrer" aria-label="<%= item.label %>">
            <svg viewBox="0 0 24 24" class="icon-stroke" aria-hidden="true">
                <%- renderIcon(item.icon) %>
            </svg>
        </a>
    <% }) %>
</div>
