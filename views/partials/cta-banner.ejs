<section class="container-shell mt-16">
    <div class="surface-card overflow-hidden px-6 py-8 sm:px-8">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-2xl">
                <% if (kicker) { %>
                    <p class="eyebrow"><%= kicker %></p>
                <% } %>
                <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl"><%= title %></h2>
                <p class="body-lg mt-3"><%= body %></p>
            </div>

            <div class="flex flex-wrap gap-3">
                <% actions.forEach(function (action, index) { %>
                    <a href="<%= action.href %>" class="<%= index === 0 ? 'btn-primary' : 'btn-secondary' %>"><%= action.label %></a>
                <% }) %>
            </div>
        </div>
    </div>
</section>
