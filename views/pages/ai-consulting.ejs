<%- include('../partials/page-shell-start', { site: site, page: page, currentPath: currentPath, extraScripts: extraScripts }) %>

<%- include('../partials/page-hero', {
    hero: {
        kicker: 'AI Consulting',
        title: 'Practical AI systems for education, creators, and small business operations.',
        description: 'I design workflows that cut repetitive work, improve output quality, and make AI feel usable instead of overwhelming.',
        actions: [
            { label: 'Book a Consultation', href: '/contact' },
            { label: 'See Example Projects', href: '/projects' },
        ],
        stats: [
            { label: 'Best fit', value: 'Education, small business, creators, startups' },
            { label: 'Focus', value: 'Workflow design + automation' },
            { label: 'Delivery', value: 'Consulting, buildouts, full system setups' },
        ],
    },
}) %>

<section class="container-shell mt-16 grid gap-6 xl:grid-cols-[1.1fr,0.9fr]">
    <div class="surface-card p-6 sm:p-8">
        <%- include('../partials/section-header', {
            kicker: 'Services Offered',
            title: 'What I can design and implement',
            body: 'The emphasis is on workflows that teams can actually maintain and use once the initial build is done.',
            centered: false,
        }) %>
        <div class="mt-6 flex flex-wrap gap-3">
            <% page.services.forEach(function (service) { %>
                <span class="chip"><%= service %></span>
            <% }) %>
        </div>
    </div>

    <div class="surface-card p-6 sm:p-8">
        <p class="eyebrow">Industries Served</p>
        <ul class="mt-5 space-y-4 text-sm leading-7 text-[var(--text-muted)]">
            <% page.industries.forEach(function (industry) { %>
                <li><%= industry %></li>
            <% }) %>
        </ul>
    </div>
</section>

<section class="container-shell mt-16">
    <%- include('../partials/section-header', {
        kicker: 'Automation Tools',
        title: 'Platforms I can connect into practical workflows',
        body: 'These tools are useful for connecting forms, spreadsheets, CRMs, content pipelines, and internal processes without adding unnecessary complexity.',
        centered: false,
    }) %>

    <div class="mt-6">
        <%- include('../partials/image-tile-grid', { items: page.tools, variant: 'logo' }) %>
    </div>
</section>

<section class="container-shell mt-16">
    <%- include('../partials/section-header', {
        kicker: 'Example Workflows',
        title: 'Workflow ideas I can help scope or build',
        body: 'These examples show the kind of repeatable, leverage-heavy systems I like to implement.',
        centered: false,
    }) %>

    <div class="site-grid mt-6">
        <% page.workflows.forEach(function (workflow) { %>
            <article class="surface-card p-6">
                <h3 class="text-xl font-semibold tracking-tight"><%= workflow.title %></h3>
                <p class="body-sm mt-3"><%= workflow.description %></p>
            </article>
        <% }) %>
    </div>
</section>

<section class="container-shell mt-16">
    <%- include('../partials/section-header', {
        kicker: 'Pricing',
        title: page.pricingTitle,
        body: page.pricingIntro,
        centered: false,
    }) %>

    <div class="site-grid mt-6">
        <% page.consultingRates.forEach(function (tier) { %>
            <article class="surface-card p-6">
                <p class="eyebrow"><%= tier.title %></p>
                <dl class="mt-5 space-y-3">
                    <% tier.rates.forEach(function (rate) { %>
                        <div class="flex flex-wrap items-baseline justify-between gap-3 border-t border-[var(--border)] pt-3">
                            <dt class="body-sm"><%= rate.label %></dt>
                            <dd class="text-sm font-semibold text-[var(--text)]"><%= rate.price %></dd>
                        </div>
                    <% }) %>
                </dl>
            </article>
        <% }) %>
    </div>
</section>

<section class="container-shell mt-16">
    <%- include('../partials/section-header', {
        kicker: 'Buildouts',
        title: page.buildoutTitle,
        body: 'Scoped systems for teams that need more than coaching or a one-off workflow session.',
        centered: false,
    }) %>

    <div class="site-grid mt-6">
        <% page.buildoutTiers.forEach(function (tier) { %>
            <article class="surface-card p-6">
                <p class="eyebrow"><%= tier.title %></p>
                <h3 class="mt-4 text-3xl font-semibold tracking-tight"><%= tier.price %></h3>
                <ul class="mt-4 space-y-2 text-sm leading-7 text-[var(--text-muted)]">
                    <% tier.bullets.forEach(function (bullet) { %>
                        <li><%= bullet %></li>
                    <% }) %>
                </ul>
                <p class="body-sm mt-4">Examples: <%= tier.examples %></p>
            </article>
        <% }) %>
    </div>
</section>

<%- include('../partials/cta-banner', {
    kicker: 'Consulting CTA',
    title: 'Book a Consultation',
    body: 'If you already have a workflow in mind, use the contact page and describe the current process, pain points, and target outcome.',
    actions: [
        { label: 'Book a Consultation', href: '/contact' },
    ],
}) %>

<%- include('../partials/page-shell-end', { site: site, year: year, extraScripts: extraScripts }) %>
