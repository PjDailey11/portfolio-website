<%- include('../partials/page-shell-start', { site: site, page: page, currentPath: currentPath, extraScripts: extraScripts }) %>

<%- include('../partials/page-hero', {
    hero: {
        kicker: 'Social Media',
        title: 'College sports lifestyle, NIL partnerships, and useful tech content.',
        description: 'I create around student-athlete life, college sports, lifestyle, AI education, productivity, and coding - with room for brand deals, affiliate marketing, and collaborations.',
        actions: [
            { label: 'Partner With Me', href: '/contact' },
            { label: 'View Instagram', href: 'https://www.instagram.com/simplydailey' },
        ],
    },
}) %>

<section class="container-shell mt-16 grid gap-6 lg:grid-cols-[0.9fr,1.1fr]">
    <div class="surface-card p-6 sm:p-8">
        <p class="eyebrow">Platforms</p>
        <div class="mt-5 flex flex-wrap gap-3">
            <% page.platforms.forEach(function (platform) { %>
                <span class="chip"><%= platform %></span>
            <% }) %>
        </div>
        <div class="mt-6">
            <%- include('../partials/social-links', { links: site.socialLinks.filter(function (item) { return ['TikTok', 'Instagram', 'YouTube', 'LinkedIn'].includes(item.label); }) }) %>
        </div>
    </div>

    <div class="surface-card p-6 sm:p-8">
        <p class="eyebrow">Content Types</p>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <% page.contentTypes.forEach(function (contentType) { %>
                <div class="rounded-3xl border border-[var(--border)] bg-[color-mix(in_srgb,var(--surface)_92%,transparent)] px-5 py-5">
                    <h3 class="text-lg font-semibold tracking-tight"><%= contentType.title %></h3>
                    <p class="body-sm mt-2"><%= contentType.description %></p>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<section class="container-shell mt-16">
    <div class="surface-card p-6 sm:p-8">
        <p class="eyebrow">Partnerships</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight">Open to creator partnerships that fit the audience.</h2>
        <div class="mt-6 flex flex-wrap gap-3">
            <% page.partnershipCategories.forEach(function (category) { %>
                <span class="chip"><%= category %></span>
            <% }) %>
        </div>
    </div>
</section>

<section class="container-shell mt-16">
    <%- include('../partials/section-header', {
        kicker: 'Profile Snapshots',
        title: 'Current social profiles and channel presence',
        body: 'Screenshots from the active platforms supporting the creator side of the portfolio.',
        centered: false,
    }) %>

    <div class="mt-6">
        <%- include('../partials/image-tile-grid', { items: page.profileImages, variant: 'profile' }) %>
    </div>
</section>

<%- include('../partials/cta-banner', {
    kicker: 'Creator CTA',
    title: 'Partner With Me',
    body: 'Use the contact form for NIL opportunities, brand deals, affiliate marketing, collaborations, or creator campaigns tied to college sports, lifestyle, AI, and tech.',
    actions: [
        { label: 'Partner With Me', href: '/contact' },
    ],
}) %>

<%- include('../partials/page-shell-end', { site: site, year: year, extraScripts: extraScripts }) %>
