<%- include('../partials/page-shell-start', { site: site, page: page, currentPath: currentPath, extraScripts: extraScripts }) %>

<%- include('../partials/page-hero', {
    hero: {
        kicker: 'Contact',
        title: 'Get in touch - tutoring, AI consulting, or anything else.',
        description: 'Use the secure form below to start a conversation about tutoring, AI consulting, creator partnerships, or technical projects.',
        actions: [
            { label: 'Go to Form', href: '#contact-form' },
            { label: 'Back to Home', href: '/' },
        ],
    },
}) %>

<section class="container-shell mt-16 grid gap-6 lg:grid-cols-[0.9fr,1.1fr]" id="contact-form">
    <div class="space-y-6">
        <div class="surface-card p-6 sm:p-8">
            <p class="eyebrow">Connect</p>
            <p class="body-sm mt-3">For privacy, direct contact details are not published. The form is the best way to reach me.</p>
            <div class="mt-5">
                <%- include('../partials/social-links', { links: site.socialLinks.filter(function (item) { return ['TikTok', 'Instagram', 'YouTube', 'LinkedIn'].includes(item.label); }) }) %>
            </div>
        </div>
    </div>

    <div class="surface-card p-6 sm:p-8">
        <p class="eyebrow">Contact Form</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight">Tell me what you need help with.</h2>
        <p class="body-sm mt-3">Use this form for tutoring, AI consulting, creator partnerships, and project inquiries.</p>
        <div class="mt-6">
            <%- include('../partials/contact-form') %>
        </div>
    </div>
</section>

<%- include('../partials/page-shell-end', { site: site, year: year, extraScripts: extraScripts }) %>
