<%- include('../partials/page-shell-start', { site: site, page: page, currentPath: currentPath, extraScripts: extraScripts }) %>

<%- include('../partials/page-hero', {
    hero: {
        kicker: 'Projects',
        title: 'Current public projects on GitHub',
        description: 'A focused portfolio of public work across educational security tooling, privacy-conscious vision systems, PyTorch experimentation, and protocol engineering.',
        actions: [
            { label: 'GitHub Profile', href: 'https://github.com/PjDailey11?tab=repositories', iconSrc: site.githubBrowseVisual.src },
            { label: 'Contact PJ', href: '/contact' },
        ],
        stats: [
            { label: 'Primary stack', value: 'Python, APIs, research tooling' },
            { label: 'Themes', value: 'Security, AI, computer vision, systems' },
            { label: 'Source', value: 'Public repositories on GitHub' },
        ],
    },
}) %>

<section class="container-shell mt-16">
    <%- include('../partials/section-header', {
        kicker: 'Selected Work',
        title: 'Selected builds that show how I approach security, AI, and systems work',
        body: 'These are the public projects that best represent the technical side of the portfolio right now, with a bias toward clear scope, strong engineering fundamentals, and honest framing.',
        centered: false,
    }) %>

    <div class="mt-6 grid gap-6 xl:grid-cols-2">
        <% projects.forEach(function (project) { %>
            <%- include('../partials/project-card', { project: project }) %>
        <% }) %>
    </div>
</section>

<section class="container-shell mt-16">
    <div class="surface-card overflow-hidden p-6 sm:p-8">
        <div class="grid gap-6 lg:grid-cols-[0.35fr,1fr] lg:items-center">
            <div class="surface-card-strong overflow-hidden p-3">
                <div class="aspect-[4/3] rounded-[1.25rem] bg-white flex items-center justify-center overflow-hidden">
                    <img src="<%= site.githubBrowseVisual.src %>" alt="<%= site.githubBrowseVisual.alt %>" class="h-full w-full rounded-[1.25rem] object-contain p-4" loading="lazy">
                </div>
            </div>
            <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
                <div class="max-w-2xl">
                    <p class="eyebrow">More repositories</p>
                    <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">Want the full repository list?</h2>
                    <p class="body-lg mt-3">The selected cards above are the most portfolio-relevant public projects, but the full GitHub profile includes more experiments and supporting repos.</p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a href="https://github.com/PjDailey11?tab=repositories" class="btn-primary">Browse GitHub</a>
                    <a href="/contact" class="btn-secondary">Contact Form</a>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/page-shell-end', { site: site, year: year, extraScripts: extraScripts }) %>
