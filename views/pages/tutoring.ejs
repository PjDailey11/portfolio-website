<%- include('../partials/page-shell-start', { site: site, page: page, currentPath: currentPath, extraScripts: extraScripts }) %>

<%- include('../partials/page-hero', {
    hero: {
        kicker: 'Tutoring',
        title: 'Math, computer science, and AI workflow tutoring with clear step-by-step instruction.',
        description: 'Support for grades 9-12, standardized tests, technical coursework, and applied problem-solving. Sessions are designed to build understanding, not just short-term answers.',
        actions: [
            { label: 'Book a Session', href: '/contact' },
        ],
        stats: [
            { label: 'Target students', value: 'Grades 9-12 + college learners' },
            { label: 'Specialties', value: 'Math, CS, test prep, AI workflows' },
            { label: 'Style', value: 'Clear, step-by-step explanations' },
        ],
    },
}) %>

<section class="container-shell mt-16">
    <div class="surface-card p-6 sm:p-8">
        <%- include('../partials/section-header', {
            kicker: 'Subjects I Tutor',
            title: 'High school through technical college-level support',
            body: 'The subject mix covers pure math, standardized test prep, core programming, and AI-enabled study workflows.',
            centered: false,
        }) %>

        <div class="mt-6 flex flex-wrap gap-3">
            <% page.subjects.forEach(function (subject) { %>
                <span class="chip"><%= subject %></span>
            <% }) %>
        </div>

        <div class="mt-8">
            <%- include('../partials/image-tile-grid', { items: page.subjectImages, variant: 'logo' }) %>
        </div>
    </div>
</section>

<section class="container-shell mt-16">
    <div class="surface-card p-6 sm:p-8" id="booking-placeholder">
        <p class="eyebrow">BOOK A SESSION</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight">Ready to schedule a session?</h2>
        <p class="body-sm mt-4">Reach out through the contact page and let me know what subject you need help with, your current level, and your availability. I'll follow up within 1–2 business days.</p>
        <div class="mt-6">
            <a href="/contact" class="btn-primary">Contact PJ</a>
        </div>
    </div>
</section>

<section class="container-shell mt-16">
    <%- include('../partials/section-header', {
        kicker: 'Pricing',
        title: 'Tutoring packages',
        body: page.pricingIntro,
        centered: false,
    }) %>

    <div class="mt-6 grid gap-6 xl:grid-cols-2">
        <% page.pricingSuites.forEach(function (suite) { %>
            <article class="surface-card p-6 sm:p-8">
                <p class="eyebrow"><%= suite.title %></p>
                <h3 class="mt-3 text-2xl font-semibold tracking-tight"><%= suite.subtitle %></h3>
                <% if (suite.description) { %>
                    <p class="body-sm mt-4"><%= suite.description %></p>
                <% } %>
                <% if (suite.bullets && suite.bullets.length) { %>
                    <ul class="mt-5 space-y-2 text-sm leading-7 text-[var(--text-muted)]">
                        <% suite.bullets.forEach(function (bullet) { %>
                            <li><%= bullet %></li>
                        <% }) %>
                    </ul>
                <% } %>
                <% if (suite.title === 'AI Scholars Suite' && page.aiToolImages && page.aiToolImages.length) { %>
                    <div class="mt-6">
                        <p class="eyebrow">AI Tutoring Tools</p>
                        <div class="mt-4">
                            <%- include('../partials/image-tile-grid', { items: page.aiToolImages, variant: 'logo' }) %>
                        </div>
                    </div>
                <% } %>

                <div class="mt-6 space-y-6">
                    <% suite.sections.forEach(function (section) { %>
                        <section>
                            <h4 class="text-base font-semibold tracking-tight"><%= section.title %></h4>

                            <% if (section.kind === 'rates') { %>
                                <dl class="mt-3 space-y-3">
                                    <% section.items.forEach(function (item) { %>
                                        <div class="flex flex-wrap items-baseline justify-between gap-3 border-t border-[var(--border)] pt-3">
                                            <dt class="body-sm"><%= item.label %></dt>
                                            <dd class="text-sm font-semibold text-[var(--text)]"><%= item.price %></dd>
                                        </div>
                                    <% }) %>
                                </dl>
                            <% } else if (section.kind === 'bullets') { %>
                                <ul class="mt-3 space-y-2 text-sm leading-7 text-[var(--text-muted)]">
                                    <% section.items.forEach(function (item) { %>
                                        <li><%= item %></li>
                                    <% }) %>
                                </ul>
                                <% if (section.footer) { %>
                                    <div class="mt-4 rounded-2xl border border-[var(--border)] bg-[color-mix(in_srgb,var(--surface)_70%,transparent)] p-4">
                                        <p class="text-sm font-semibold text-[var(--text)]"><%= section.footer.label %>: <%= section.footer.price %></p>
                                    </div>
                                <% } %>
                            <% } else if (section.kind === 'comparison') { %>
                                <div class="mt-3 overflow-x-auto">
                                    <table class="w-full min-w-[32rem] text-left text-sm">
                                        <thead class="text-[var(--text)]">
                                            <tr>
                                                <th class="border-b border-[var(--border)] py-3 pr-4 font-semibold">Service</th>
                                                <% section.columns.forEach(function (column) { %>
                                                    <th class="border-b border-[var(--border)] px-4 py-3 font-semibold"><%= column %></th>
                                                <% }) %>
                                            </tr>
                                        </thead>
                                        <tbody class="text-[var(--text-muted)]">
                                            <% section.rows.forEach(function (row) { %>
                                                <tr>
                                                    <th class="border-b border-[var(--border)] py-3 pr-4 font-medium text-[var(--text)]"><%= row.label %></th>
                                                    <% row.values.forEach(function (value) { %>
                                                        <td class="border-b border-[var(--border)] px-4 py-3"><%= value %></td>
                                                    <% }) %>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        </section>
                    <% }) %>
                </div>
            </article>
        <% }) %>
    </div>
</section>

<section class="container-shell mt-16">
    <%- include('../partials/section-header', {
        kicker: 'Add-ons',
        title: 'Optional session support',
        body: 'Add focused support when a student needs extra structure between sessions.',
        centered: false,
    }) %>

    <div class="site-grid mt-6">
        <% page.addOns.forEach(function (addOn) { %>
            <article class="surface-card p-6">
                <p class="body-sm"><%= addOn.label %></p>
                <p class="mt-3 text-2xl font-semibold tracking-tight"><%= addOn.price %></p>
            </article>
        <% }) %>
    </div>
</section>

<div class="fixed inset-x-4 bottom-4 z-30 lg:hidden">
    <a href="/contact" class="btn-primary flex w-full justify-center">Book a Session</a>
</div>

<%- include('../partials/page-shell-end', { site: site, year: year, extraScripts: extraScripts }) %>
