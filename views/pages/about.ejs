<%- include('../partials/page-shell-start', { site: site, page: page, currentPath: currentPath, extraScripts: extraScripts }) %>

<%- include('../partials/page-hero', {
    hero: {
        kicker: 'About Me',
        title: 'A teaching-first operator who also builds technical systems.',
        description: page.bio,
        actions: [
            { label: 'Explore Tutoring', href: '/tutoring' },
            { label: 'Explore AI Consulting', href: '/ai-consulting' },
        ],
        visual: 'portrait',
    },
}) %>

<section class="container-shell mt-16 grid gap-6 lg:grid-cols-[1.2fr,0.8fr]">
    <div class="surface-card p-6 sm:p-8">
        <%- include('../partials/section-header', {
            kicker: 'Accomplishments',
            title: 'What I have been building and teaching',
            body: 'The portfolio spans academic coaching, full-stack implementation, AI systems thinking, and content creation.',
            centered: false,
        }) %>
        <div class="mt-6 space-y-8">
            <div>
                <h3 class="text-lg font-semibold tracking-tight">TUTORING &amp; TEACHING:</h3>
                <ul class="list-check mt-4 space-y-4 text-sm leading-7 text-[var(--text-muted)]">
                    <li>Runs an active tutoring business serving grades 9-12 and college students.</li>
                    <li>Tutors: SAT/ACT Math, Algebra I &amp; II through Calculus II, Linear Algebra, Computer Science (Python, JS, C), Data Structures &amp; Algorithms, LeetCode prep, and AI workflow instruction.</li>
                    <li>Known for step-by-step explanations that build lasting conceptual understanding.</li>
                </ul>
            </div>

            <div>
                <h3 class="text-lg font-semibold tracking-tight">BUILDING &amp; DEVELOPMENT:</h3>
                <ul class="list-check mt-4 space-y-4 text-sm leading-7 text-[var(--text-muted)]">
                    <li>Built multiple full-stack web applications using Express, EJS, SQLite, and TailwindCSS.</li>
                    <li>Strong foundations in linear algebra, logic proofs, number theory, and algorithm design.</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="space-y-6">
        <div class="surface-card p-6">
            <p class="eyebrow">Accolades</p>
            <p class="body-sm mt-5">References and student outcome examples are available on request.</p>
        </div>

        <div class="surface-card p-6">
            <p class="eyebrow">Education</p>
            <ul class="mt-5 space-y-4 text-sm leading-7 text-[var(--text-muted)]">
                <% page.education.forEach(function (item) { %>
                    <li><%= item %></li>
                <% }) %>
            </ul>
        </div>

        <div class="surface-card p-6">
            <p class="eyebrow">Athletics</p>
            <p class="body-sm mt-4">Former Division II college baseball athlete at St. Edward's University.</p>
        </div>
    </div>
</section>

<%- include('../partials/cta-banner', {
    kicker: 'Next step',
    title: 'Want to work with me as a tutor, consultant, or creator partner?',
    body: 'The tutoring, AI consulting, and contact pages break down exactly how I work.',
    actions: [
        { label: 'See Tutoring', href: '/tutoring' },
        { label: 'Book a Call', href: '/contact' },
    ],
}) %>

<%- include('../partials/page-shell-end', { site: site, year: year, extraScripts: extraScripts }) %>
