{
  "name": "pj-dailey-portfolio",
  "version": "1.0.0",
  "description": "Modern portfolio website for PJ Dailey",
  "main": "server.js",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/app.css -o ./public/assets/app.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./src/styles/app.css -o ./public/assets/app.css --watch",
    "dev": "concurrently \"npm:watch:css\" \"node --watch server.js\"",
    "prestart": "npm run build",
    "start": "node server.js",
    "lint": "eslint server.js routes/**/*.js src/**/*.js public/js/**/*.js --no-error-on-unmatched-pattern"
  },
  "keywords": [
    "portfolio",
    "website",
    "developer"
  ],
  "author": "PJ Dailey",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "ejs": "^5.0.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "tailwindcss": "^4.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
